      "source": [
        "from fastapi import FastAPI, Query\n",
        "from typing import Optional\n",
        "import nest_asyncio\n",
        "from pyngrok import ngrok\n",
        "import uvicorn\n",
        "import numpy as np\n",
        "from sklearn.metrics import pairwise_distances\n",
        "\n",
        "app = FastAPI(title=\"API Educaci3n Colombia - Clustering\")\n",
        "nest_asyncio.apply()\n",
        "\n",
        "@app.get(\"/health\")\n",
        "def health():\n",
        "    return {\"status\": \"ok\", \"message\": \"API de clustering educativo funcionando\"}\n",
        "\n",
        "@app.get(\"/metadata\")\n",
        "def get_metadata():\n",
        "    return {\n",
        "        \"dataset\": \"Estad1sticas educaci3n preescolar, b1sica y media\",\n",
        "        \"variables\": engine.features,\n",
        "        \"modelo\": \"K-Means\",\n",
        "        \"clusters\": engine.n_clusters\n",
        "    }\n",
        "\n",
        "@app.get(\"/cluster/municipios\")\n",
        "def get_cluster_municipios(departamento: Optional[str] = None):\n",
        "    df = engine.df_processed\n",
        "    if departamento:\n",
        "        df = df[df['departamento'].str.contains(departamento, case=False, na=False)]\n",
        "    return df[['departamento', 'municipio', 'cluster']].to_dict(orient='records')\n",
        "\n",
        "@app.get(\"/cluster/municipio\")\n",
        "def get_cluster_municipio(municipio: str, departamento: str):\n",
        "    df = engine.df_processed\n",
        "    match = df[(df['municipio'].str.contains(municipio, case=False, na=False)) &\n",
        "               (df['departamento'].str.contains(departamento, case=False, na=False))]\n",
        "    if match.empty: return {\"error\": \"Municipio no encontrado\"}\n",
        "    row = match.iloc[0]\n",
        "    cluster_id = int(row['cluster'])\n",
        "    return {\n",
        "        \"municipio\": row['municipio'],\n",
        "        \"departamento\": row['departamento'],\n",
        "        \"cluster\": cluster_id,\n",
        "        \"perfil_promedio\": engine.interpretar_clusters()[cluster_id]\n",
        "    }\n",
        "\n",
        "@app.get(\"/recomendaciones\")\n",
        "def get_recomendaciones(municipio: str, departamento: str):\n",
        "    # L3gica de recomendaci3n basada en el cl1ster\n",
        "    res = get_cluster_municipio(municipio, departamento)\n",
        "    if \"error\" in res: return res\n",
        "\n",
        "    cluster = res[\"cluster\"]\n",
        "    recomendaciones = {\n",
        "        0: \"Priorizar programas de retenci3n escolar en secundaria.\",\n",
        "        1: \"Fortalecer la infraestructura tecnol3gica y conectividad.\",\n",
        "        2: \"Incrementar la inversi3n en educaci3n inicial y preescolar.\",\n",
        "        3: \"Fomentar la transici3n a educaci3n superior.\",\n",
        "        4: \"Mejorar los ratios de docente por estudiante.\"\n",
        "    }\n",
        "    return {\n",
        "        \"municipio\": municipio,\n",
        "        \"cluster\": cluster,\n",
        "        \"recomendacion_sugerida\": recomendaciones.get(cluster, \"Analizar indicadores de cobertura.\")\n",
        "    }"
      ],
