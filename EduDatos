        "id": "4d33cf9f",
        "outputId": "1d9c80ea-7a5f-4583-cc1a-1390fd192de1"
      },
      "source": [
        "import pandas as pd\n",
        "import requests\n",
        "\n",
        "DATASET_URL = \"https://www.datos.gov.co/resource/nudc-7mev.json\"\n",
        "\n",
        "def consultar_datos_colombia(url, limit=1000000):\n",
        "    try:\n",
        "        response = requests.get(f\"{url}?$limit={limit}\")\n",
        "        response.raise_for_status()\n",
        "        df = pd.DataFrame(response.json())\n",
        "        return df\n",
        "    except Exception as e:\n",
        "        print(f\"Error al cargar datos: {e}\")\n",
        "        return None\n",
        "\n",
        "# Exploración inicial\n",
        "df_educacion = consultar_datos_colombia(DATASET_URL)\n",
        "print(f\"Registros cargados: {len(df_educacion)}\")\n",
        "display(df_educacion.head())\n",
        "print(\"Columnas disponibles:\", df_educacion.columns.tolist())"
      ],
